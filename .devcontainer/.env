# =============================================================
# Kivio devcontainer environment — DEV USE ONLY
# Service URLs are intentionally overridden in docker-compose.yml
# Add your real API keys below (this file is git-ignored locally)
# =============================================================

# JWT (dev-only secret — never reuse in staging/production)
JWT_SECRET=kivio-dev-jwt-secret-do-not-use-in-production-minimum-32-bytes
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# Google OAuth (fill in for Phase 2 Google login testing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (test mode — fill in for Phase 3+ payment testing)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Cloudinary (fill in for Phase 3+ image upload testing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (locally Mailpit handles emails — set real key for E2E test)
RESEND_API_KEY=re_test_
RESEND_FROM_EMAIL=noreply@localhost

# Claude Code
ANTHROPIC_API_KEY=
